{
	"version": 1,
	"hooks": {
		"PostToolUse": [
			{
				"name": "biome-fix",
				"command": "npx biome check --write ."
			},
			{
				"name": "biome-check",
				"command": "npx biome check ."
			},
			{
				"name": "ts-check",
				"command": "npx tsc --noEmit"
			}
		],
		"SessionEnd": [
			{
				"name": "final-validation",
				"command": "npm test"
			}
		]
	}
}