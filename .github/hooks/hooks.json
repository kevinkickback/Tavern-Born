{
	"version": 1,
	"hooks": {
		"PostToolUse": [
			{
				"name": "biome-fix",
				"command": "npx biome check --write .",
				"include": [
					"**/*.{ts,tsx,js,jsx}"
				],
				"exclude": [
					"dist/**",
					"build/**",
					"node_modules/**"
				]
			},
			{
				"name": "ts-check",
				"command": "npx tsc --noEmit --incremental --pretty false",
				"include": [
					"**/*.{ts,tsx}"
				],
				"exclude": [
					"dist/**",
					"build/**",
					"node_modules/**"
				]
			}
		],
		"SessionEnd": [
			{
				"name": "final-validation",
				"command": "npm test"
			}
		]
	}
}